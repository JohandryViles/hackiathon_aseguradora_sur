# Convex
# Convex deployment name
CONVEX_DEPLOYMENT=
# Convex deployment URL (required)
VITE_CONVEX_URL=

# OpenAI se configura como variable segura de Convex, no como VITE_:
# npx convex env set OPENAI_API_KEY "sk-..."
# Opcionales:
# npx convex env set OPENAI_MODEL "gpt-4.1-mini"
# npx convex env set OPENAI_SYSTEM_MESSAGE "Eres un analista antifraude..."
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SYSTEM_MESSAGE="Eres un analista antifraude de seguros para Aseguradora del Sur. Responde en espanol, breve y claro. Usa solo los datos entregados en el contexto y no acuses fraude como hecho confirmado."
